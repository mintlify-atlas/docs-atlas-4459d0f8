{
  "projectType": "sdk-library",
  "projectName": "Compose Svelted",
  "projectDescription": "A Jetpack Compose-inspired UI component library for Svelte that brings declarative layout, immutable modifiers, structural motion, and compose-like navigation to the web — without virtual DOM abstractions.",
